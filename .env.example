# ============================
# AgentFoundry Environment
# ============================

# OpenAI API key (required for agent test + skill builder)
OPENAI_API_KEY=your-openai-api-key-here

# Optional: API key to protect skill mutation endpoints (POST/PUT/DELETE)
# If not set, auth is disabled for easy local development
# When set, callers must send: Authorization: Bearer <key>  OR  X-API-Key: <key>
AGENT_FOUNDRY_API_KEY=your-secret-api-key-here

# MongoDB connection string (optional — used if you deploy a persistent skill store)
MONGODB_URI=mongodb+srv://...

# GitHub token (for Gist export feature)
GITHUB_TOKEN=your-github-token-here
