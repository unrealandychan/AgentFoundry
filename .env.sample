# AgentFoundry — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.

# ─── OpenAI ────────────────────────────────────────────────────────────────────
# Required for the "Test Agent" step.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: Override the default model used in /api/test-agent
# Supported: gpt-4o-mini (default), gpt-4o, gpt-4.1, gpt-5.4
OPENAI_MODEL=gpt-4o-mini

# Optional: Override the OpenAI API base URL.
# Use this to point at any OpenAI-compatible API (Ollama, LM Studio, Azure OpenAI, etc.)
# Example for Ollama:       OPENAI_BASE_URL=http://localhost:11434/v1
# Example for LM Studio:    OPENAI_BASE_URL=http://localhost:1234/v1
# Example for Azure OpenAI: OPENAI_BASE_URL=https://<resource>.openai.azure.com/openai/deployments/<deployment>
OPENAI_BASE_URL=

# ─── OpenAI Agents SDK (optional, for production deploys) ─────────────────────
# When running the generated AGENTS.md with the OpenAI Agents SDK:
#   pip install "openai-agents>=0.14.0"
#   export OPENAI_API_KEY=sk-...
#   python -c "from agents import Runner; ..."
#
# Trace runs (optional — enables the OpenAI dashboard trace viewer):
OPENAI_TRACE_ENABLED=false

# ─── Anthropic / Claude (optional) ────────────────────────────────────────────
# If you export a CLAUDE.md target and want to invoke claude-code directly:
ANTHROPIC_API_KEY=sk-ant-...

# ─── GitHub (optional) ────────────────────────────────────────────────────────
# Used by the MCP GitHub server and the GitHub import feature if you
# need to scan private repos (public repos work without a token).
GITHUB_TOKEN=ghp_...

# ─── MCP Server environment variables ─────────────────────────────────────────
# Some MCP servers require API keys. Set them here and they will be
# referenced by the generated mcp.json file.

# Brave Search MCP server (optional)
BRAVE_API_KEY=

# Pinecone vector store (optional, for RAG templates)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# ─── App config ───────────────────────────────────────────────────────────────
# The public URL of your deployed app (used for OpenGraph metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Storage backend ──────────────────────────────────────────────────────────
# Offline / self-hosted (default): leave MONGODB_URI unset.
#   Skills are served from the bundled registry/skills.json — read-only.
#
# Enterprise / cloud: set MONGODB_URI to enable full skill CRUD via the API.
#   The collection is seeded automatically from skills.json on first start.
#   Use docker-compose.yml for a local MongoDB instance.
#
# Example (local Docker):   MONGODB_URI=mongodb://localhost:27017/agentfoundry
# Example (Atlas):          MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/agentfoundry
MONGODB_URI=

# Optional: override the default database name (default: agentfoundry)
MONGODB_DB_NAME=agentfoundry
